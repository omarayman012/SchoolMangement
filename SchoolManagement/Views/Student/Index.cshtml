@model IEnumerable<SchoolManagement.Domain.Entities.Student>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">قائمة الطلاب</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus"></i> إضافة طالب جديد
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-primary text-center">
                    <tr>
                        <th style="width: 10%;">#</th>
                        <th>الاسم الكامل</th>
                    </tr>
                </thead>
                <tbody class="text-center">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="2" class="py-4 text-muted">لا يوجد طلاب</td>
                        </tr>
                    }
                    else
                    {
                        int i = 1;
                        foreach (var student in Model)
                        {
                            <tr>
                                <td>@i</td>
                                <td class="text-start ps-4">@student.FullName</td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f8f9fa;
        color: #343a40;
    }

    .card {
        border-radius: 12px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

    .table thead {
        font-weight: 600;
        color: white;
    }

    .table tbody tr:hover {
        background-color: #e9f2ff;
        transition: 0.3s;
    }

    .table td, .table th {
        vertical-align: middle;
        text-align: center;
        padding: 12px 15px;
    }

    .table tbody td:nth-child(2) {
        text-align: left;
        padding-left: 20px;
    }

    .btn-primary {
        font-weight: 600;
        transition: background-color 0.2s, transform 0.2s;
    }

        .btn-primary:hover {
            background-color: #0b5ed7;
            transform: translateY(-2px);
        }
</style>